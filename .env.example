# Copy to .env for local development (the ./omni-websearch wrapper loads this file).
# This file is an example only — it is committed; .env is gitignored and never committed.
# Real usage (bunx / bun link) is env-only: export these yourself, do NOT rely on .env.

OMNIROUTE_CUSTOM_WEBSEARCH_URL=https://omniroute.domain.id
OMNIROUTE_API_KEY=sk-your-key-here
