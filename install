#!/usr/bin/env sh
# omni-websearch installer — opencode-style.
# Detects OS/arch, downloads the matching CI-built Release asset, installs to
# ~/.local/bin, and verifies it is on PATH. No bun/node required at runtime.
set -eu

REPO="eliteraihan2nd/omniroute-websearch-cli"
BIN="omni-websearch"
INSTALL_DIR="${XDG_BIN_DIR:-$HOME/.local/bin}"

# --- detect OS/arch (mirrors opencode's install.sh) ---
raw_os=$(uname -s)
os=$(echo "$raw_os" | tr '[:upper:]' '[:lower:]')
case "$raw_os" in
  Linux*)  os="linux" ;;
  *)
    echo "Unsupported OS: $raw_os — binaries are built for Linux only." >&2
    exit 1
    ;;
esac

arch=$(uname -m)
case "$arch" in
  x86_64|amd64)  arch="x64" ;;
  aarch64|arm64) arch="arm64" ;;
  *)
    echo "Unsupported arch: $arch" >&2
    exit 1
    ;;
esac

asset="omni-websearch-${os}-${arch}"
url="https://github.com/${REPO}/releases/latest/download/${asset}"

mkdir -p "$INSTALL_DIR"
tmp=$(mktemp)

echo "Installing ${BIN} (${os}-${arch}) -> ${INSTALL_DIR}/${BIN}"
if command -v curl >/dev/null 2>&1; then
  curl -fsSL "$url" -o "$tmp"
elif command -v wget >/dev/null 2>&1; then
  wget -qO "$tmp" "$url"
else
  echo "Error: curl or wget required." >&2
  rm -f "$tmp"
  exit 1
fi

mv "$tmp" "${INSTALL_DIR}/${BIN}"
chmod +x "${INSTALL_DIR}/${BIN}"

# --- PATH check ---
case ":$PATH:" in
  *":$INSTALL_DIR:"*) ;;
  *)
    echo ""
    echo "Note: $INSTALL_DIR is not on your PATH."
    echo "Add it to your shell profile, e.g.:"
    echo "  export PATH=\"$INSTALL_DIR:\$PATH\""
    ;;
esac

echo "Done. Run: ${BIN} healthcheck"
